# Secret key for JWT token signing. Generate a strong random key for production.
# Example: openssl rand -hex 32
SECRET_KEY=changeme-super-secret-key-for-development

# Default admin account credentials created on first startup.
# Change these immediately in production.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin

# Database connection URL.
# SQLite (development default):
DATABASE_URL=sqlite+aiosqlite:///./stockpilot.db
# PostgreSQL (production example):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stockpilot